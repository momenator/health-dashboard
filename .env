APP_NAME=Health Dashboard Backend
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

DATABASE_URL=sqlite:///./health_dashboard.db

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://lovable.dev
LOVABLE_WEBHOOK_URL=
LOVABLE_API_KEY=

AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

ENABLE_BEDROCK=true
BEDROCK_MODEL_ID=us.mistral.pixtral-large-2502-v1:0

REPORT_STORAGE_BACKEND=local
REPORTS_DIR=./data/reports
S3_REPORTS_BUCKET=
S3_REPORTS_PREFIX=reports
