AWS_REGION=eu-central-1
AWS_ACCOUNT_ID=123456789012

ECR_REPOSITORY=health-dashboard-backend

ECS_CLUSTER_NAME=health-dashboard-cluster
ECS_SERVICE_NAME=health-dashboard-service
ECS_TASK_FAMILY=health-dashboard-task
ECS_CONTAINER_NAME=health-dashboard-api
ECS_CONTAINER_PORT=8000
ECS_CPU=1024
ECS_MEMORY=2048
ECS_DESIRED_COUNT=1
ECS_LOG_GROUP=/ecs/health-dashboard
ECS_LOG_STREAM_PREFIX=ecs
ECS_ASSIGN_PUBLIC_IP=ENABLED

# Comma-separated existing subnet and security group IDs. For the simplified setup, use public subnets.
ECS_SUBNET_IDS=subnet-abc123,subnet-def456
ECS_SECURITY_GROUP_IDS=sg-abc123

# Recommended for a stable public URL.
ECS_TARGET_GROUP_ARN=arn:aws:elasticloadbalancing:eu-central-1:123456789012:targetgroup/health-dashboard/abc123
ECS_HEALTHCHECK_GRACE_PERIOD_SECONDS=60
ECS_ALB_DNS_NAME=health-dashboard-alb-123456.eu-central-1.elb.amazonaws.com

# Required for ECS tasks.
ECS_EXECUTION_ROLE_ARN=arn:aws:iam::123456789012:role/ecsTaskExecutionRole
ECS_TASK_ROLE_ARN=arn:aws:iam::123456789012:role/HealthDashboardEcsTaskRole

APP_ENV=production
ALLOWED_ORIGINS=https://your-lovable-app.example
ENABLE_BEDROCK=true
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

REPORT_STORAGE_BACKEND=s3
S3_REPORTS_BUCKET=your-report-bucket
S3_REPORTS_PREFIX=reports

# Use one of these two database options:
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL_SECRET_ARN=arn:aws:secretsmanager:eu-central-1:123456789012:secret:health-dashboard/database-url

# Optional Lovable callback config:
LOVABLE_WEBHOOK_URL=
# LOVABLE_API_KEY_SECRET_ARN=arn:aws:secretsmanager:eu-central-1:123456789012:secret:health-dashboard/lovable-api-key
