# App
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000

# LLM Backend - OpenAI (recommended) or AWS Bedrock
# Set your OpenAI API key here. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL_ID=gpt-4o-mini

# Groq (for location news summarization, optional)
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=

# AWS credentials (only needed if using Bedrock instead of OpenAI)
AWS_REGION=us-west-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Amazon Bedrock (only used if OPENAI_API_KEY is empty)
ENABLE_BEDROCK=false
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
# Optional per-role model overrides:
# BEDROCK_ROUTER_MODEL_ID=
# BEDROCK_QUERY_MODEL_ID=
# BEDROCK_ANSWER_MODEL_ID=
# BEDROCK_CHART_MODEL_ID=
# BEDROCK_RECOMMENDATION_MODEL_ID=
# BEDROCK_REPORT_MODEL_ID=

# Athena (for production)
ATHENA_DATABASE=ai4good_health
ATHENA_OUTPUT_S3=s3://ai4good-athena-results/
REPORTING_S3_PREFIX=s3://ai4good-health-data/ai4good-health/reporting/2026/

# Data
ALLOWED_TABLES=ambulance_causes,ambulance_trips,community_workers,mchp_patient_support,sensitization_activities,tb_patient_journey,reporting_catalog
MAX_QUERY_ROWS=1000
DATA_DIR=data/reporting

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://lovable.dev

# Lovable integration (optional)
# LOVABLE_WEBHOOK_URL=
# LOVABLE_API_KEY=

# Legacy (unused in chatbot mode)
DATABASE_URL=sqlite:///./health_dashboard.db
