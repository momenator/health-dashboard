# App
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000

# AWS credentials (optional for Athena/S3 deployments)
AWS_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# OpenAI
ENABLE_OPENAI=true
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-5.5
# OPENAI_ROUTER_MODEL=gpt-5.5
# OPENAI_QUERY_MODEL=gpt-5.5
# OPENAI_ANSWER_MODEL=gpt-5.5
# OPENAI_CHART_MODEL=gpt-5.5
# OPENAI_RECOMMENDATION_MODEL=gpt-5.5
# OPENAI_REPORT_MODEL=gpt-5.5

# Optional: Groq is used only to rank/summarize public context signals.
# Without this key, the app uses deterministic relevance scoring.
ENABLE_GROQ_CONTEXT=false
GROQ_API_KEY=gsk-your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant

# Athena (for production)
ATHENA_DATABASE=ai4good_health
ATHENA_OUTPUT_S3=s3://ai4good-athena-results/
REPORTING_S3_PREFIX=s3://ai4good-health-data/ai4good-health/reporting/2026/

# Data
ALLOWED_TABLES=ambulance_causes,ambulance_trips,community_workers,mchp_patient_support,sensitization_activities,tb_patient_journey,reporting_catalog
MAX_QUERY_ROWS=1000
DATA_DIR=data/reporting
UPLOAD_RAW_DIR=/tmp/health-dashboard/uploads/raw
UPLOAD_QUARANTINE_DIR=/tmp/health-dashboard/uploads/quarantine
# PII_SANITIZER_SCRIPT=/absolute/path/to/remove_pii.py

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,https://lovable.dev
ALLOWED_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1|\[::1\])(:\d+)?$

# Lovable integration (optional)
# LOVABLE_WEBHOOK_URL=
# LOVABLE_API_KEY=

# Legacy (unused in chatbot mode)
DATABASE_URL=sqlite:///./health_dashboard.db
