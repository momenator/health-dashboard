{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReportsBucketAccess",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject"
      ],
      "Resource": "arn:aws:s3:::YOUR_REPORT_BUCKET/*"
    },
    {
      "Sid": "ReadSecrets",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue"
      ],
      "Resource": [
        "arn:aws:secretsmanager:YOUR_REGION:YOUR_ACCOUNT_ID:secret:health-dashboard/*"
      ]
    },
    {
      "Sid": "DecryptSecretsKmsKey",
      "Effect": "Allow",
      "Action": [
        "kms:Decrypt"
      ],
      "Resource": [
        "arn:aws:kms:YOUR_REGION:YOUR_ACCOUNT_ID:key/YOUR_KMS_KEY_ID"
      ]
    }
  ]
}
